# Server-side only — used by the dev shim (vite.config.js) and the production
# serverless function (api/forensic-summary.js). NOT exposed to the browser
# (no VITE_ prefix). Copy to .env for local dev and set the same vars in your
# host (e.g. Vercel Project Settings → Environment Variables) for production.

ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Optional — model used for the Earning Quality summary. Defaults to a fast,
# low-cost model. Use a larger model for deeper analysis.
# FORENSIC_SUMMARY_MODEL=claude-haiku-4-5
